{
  "name": "sci-map-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Static, browser-rendered Social Connectedness Index map maker",
  "scripts": {
    "dev": "npm run prepare:cgfr && vite",
    "check:js": "find src scripts ../export \\( -name '*.js' -o -name '*.mjs' \\) -print -exec node --check {} \\;",
    "prepare:cgfr": "node scripts/build_cgfr_data.mjs",
    "precompute": "node scripts/precompute_clusters.mjs",
    "build": "npm run prepare:cgfr && vite build",
    "preview": "vite preview",
    "deploy": "npm run build && npx wrangler@latest pages deploy dist --project-name social-connectedness"
  },
  "dependencies": {
    "mp4-muxer": "^5.1.3"
  },
  "devDependencies": {
    "vite": "^5.4.10"
  }
}
