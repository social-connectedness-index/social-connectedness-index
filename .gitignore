private_keys.json

# Web app (Node/Vite)
web/node_modules
web/dist
web/.wrangler
# Local env files (optional Vite/Cloudflare settings; kept out of git)
web/.env
web/.env.local
web/.env.*.local
# Note: web/public/data/ (R-exported map assets) is already covered by the "data"
# rule above. It is deployed via `wrangler pages deploy` from web/dist, not git.

